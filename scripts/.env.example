# API Keys
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
ZHIPUAI_API_KEY=

# ============================================
# LLM选择 (DEEPSEEK 或 ZHIPUAI)
# ============================================
LLM_PROVIDER=DEEPSEEK

# ============================================
# 邮件服务选择
# USE_GMAIL=true 使用 Gmail
# USE_GMAIL=false 使用 QQ/163 邮箱
# ============================================
USE_GMAIL=false

# ============================================
# 163邮箱配置
# ============================================
MY_EMAIL=
NETEASE_EMAIL_AUTH_CODE=
NETEASE_SMTP_SERVER=smtp.163.com
NETEASE_SMTP_PORT=465
NETEASE_IMAP_SERVER=imap.163.com
NETEASE_IMAP_PORT=993

# ============================================
# QQ邮箱配置 (备用)
# ============================================
MY_EMAIL=
QQ_EMAIL_AUTH_CODE=
QQ_SMTP_SERVER=smtp.qq.com
QQ_SMTP_PORT=465
QQ_IMAP_SERVER=imap.qq.com
QQ_IMAP_PORT=993

# ============================================
# 代理配置
# ============================================
